---
import { Image } from 'astro:assets';
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import ArticleSchema from '../components/seo/ArticleSchema.astro';
import { absolute } from '../lib/seo';

interface Props {
  entry: CollectionEntry<'actualites'>;
}

const { entry } = Astro.props;
const a = entry.data;
const { Content } = await render(entry);

const dateFmt = new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long' });
const publishedLabel = dateFmt.format(a.datePublication);
const updatedLabel = a.dateMaj ? dateFmt.format(a.dateMaj) : null;

const trail = [
  { label: 'Accueil', href: '/' },
  { label: 'Actualités', href: '/blog/' },
  { label: a.title, href: Astro.url.pathname },
];

const pageUrl = absolute(Astro.url.pathname);
const shareText = encodeURIComponent(a.title);
const shareUrl = encodeURIComponent(pageUrl);
const facebookShare = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;
const xShare = `https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`;
const emailShare = `mailto:?subject=${shareText}&body=${shareUrl}`;
---

<BaseLayout title={a.seoTitle ?? a.title} description={a.description} image={a.image?.src}>
  <Fragment slot="head">
    <BreadcrumbSchema trail={trail} />
    <ArticleSchema
      title={a.title}
      description={a.description}
      url={pageUrl}
      datePublished={a.datePublication.toISOString()}
      dateModified={a.dateMaj?.toISOString()}
      image={a.image ? absolute(a.image.src) : undefined}
    />
  </Fragment>

  <Breadcrumbs trail={trail} />

  <article class="mx-auto max-w-3xl px-4 pb-16">
    <header>
      <h1 class="font-brand text-3xl font-bold leading-tight text-sky-deep sm:text-4xl">{a.title}</h1>
      <p class="mt-3 text-sm text-ink/60">
        <time datetime={a.datePublication.toISOString()}>Publié le {publishedLabel}</time>
        {updatedLabel && <span> · Mis à jour le {updatedLabel}</span>}
      </p>
      {a.tags.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-2">
          {a.tags.map((tag) => (
            <li class="rounded-full bg-sky/15 px-2.5 py-0.5 text-xs font-medium text-sky-deep">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    {a.image && (
      <figure class="mt-6">
        <Image
          src={a.image}
          alt={a.imageAlt ?? ''}
          widths={[400, 700, 1000]}
          sizes="(min-width: 768px) 720px, 92vw"
          class="w-full rounded-2xl shadow-sm"
          loading="eager"
        />
      </figure>
    )}

    <div class="prose-cap mt-8 text-lg leading-relaxed [&_a]:text-sky-deep [&_a]:underline [&_h2]:mt-8 [&_h2]:font-brand [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-sky-deep [&_p]:mt-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6">
      <Content />
    </div>

    <footer class="mt-10 border-t border-sky/15 pt-6">
      <p class="text-sm font-semibold text-ink/70">Partager cet article</p>
      <div class="mt-3 flex items-center gap-3">
        <a href={facebookShare} target="_blank" rel="noopener" aria-label="Partager sur Facebook" class="text-sky-deep transition-colors hover:text-orange">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z" /></svg>
        </a>
        <a href={xShare} target="_blank" rel="noopener" aria-label="Partager sur X" class="text-sky-deep transition-colors hover:text-orange">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M18.24 2H21l-6.55 7.5L22.5 22h-6.83l-4.6-6.02L5.8 22H3l7.03-8.03L1.5 2h7l4.16 5.5L18.24 2Zm-1.2 18h1.6L6.9 3.7H5.2l11.84 16.3Z" /></svg>
        </a>
        <a href={emailShare} aria-label="Partager par e-mail" class="text-sky-deep transition-colors hover:text-orange">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
