---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';

// The STEM piece lives at its flat legacy URL; everything else lives under /blog/.
const FLAT_SLUGS = new Set(['histoire-avions-papier']);

const articles = (await getCollection('actualites', (e) => !e.data.draft))
  .sort((a, b) => b.data.datePublication.getTime() - a.data.datePublication.getTime())
  .map((e) => ({
    entry: e,
    href: FLAT_SLUGS.has(e.id) ? `/${e.id}/` : `/blog/${e.id}/`,
  }));

const dateFmt = new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long' });

const seoTitle = 'Actualités — Championnat du Monde de Lancer d’Avions en Papier';
const seoDescription =
  'Les actualités du Championnat du Monde de lancer d’avions en papier à Mérignac : annonces de l’édition 2026, cause soutenue, histoire et culture de l’avion en papier.';

const breadcrumb = [
  { label: 'Accueil', href: '/' },
  { label: 'Actualités', href: '/blog/' },
];
---

<PageLayout title="Actualités" seoTitle={seoTitle} seoDescription={seoDescription} breadcrumb={breadcrumb}>
  <p class="text-lg text-ink/80">
    Toute l’actualité du Championnat : annonces de l’édition 2026, coulisses, et articles de fond sur l’univers de l’avion en papier.
  </p>

  <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
    {articles.map(({ entry, href }) => (
      <li class="overflow-hidden rounded-2xl border border-sky/15 bg-white shadow-sm transition-shadow hover:shadow-md">
        <a href={href} class="flex h-full flex-col">
          {entry.data.image && (
            <div class="aspect-[16/9] overflow-hidden bg-paper">
              <Image
                src={entry.data.image}
                alt={entry.data.imageAlt ?? ''}
                widths={[400, 700]}
                sizes="(min-width: 640px) 45vw, 90vw"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          )}
          <div class="flex flex-1 flex-col p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-ink/50">
              <time datetime={entry.data.datePublication.toISOString()}>{dateFmt.format(entry.data.datePublication)}</time>
            </p>
            <h2 class="mt-2 font-brand text-lg font-bold leading-snug text-sky-deep">{entry.data.title}</h2>
            <p class="mt-2 text-sm text-ink/70">{entry.data.description}</p>
            <span class="mt-auto pt-4 text-sm font-semibold text-orange">Lire l’article →</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</PageLayout>
