---
import { getEntry, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const page = await getEntry('pages', 'imprimer');
const { Content } = await render(page!);

const breadcrumb = [
  { label: 'Accueil', href: '/' },
  { label: 'Tutoriels', href: '/ressources-avions-papier/' },
  { label: 'Avion en papier à imprimer', href: '/avion-papier-a-imprimer/' },
];
---

<PageLayout
  title={page!.data.title}
  seoTitle={page!.data.seoTitle}
  seoDescription={page!.data.seoDescription}
  image={page!.data.image?.src}
  breadcrumb={breadcrumb}
>
  <Content />
</PageLayout>
