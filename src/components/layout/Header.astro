---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import Nav from './Nav.astro';
import logo from '../../assets/event/logo-championnat.png';

const reglages = await getEntry('reglages', 'reglages');
const helloAssoUrl = reglages?.data.helloAssoUrl ?? '#';
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-sky/20 bg-paper/95 backdrop-blur supports-[backdrop-filter]:bg-paper/80">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-2.5">
    <a href="/" class="flex items-center gap-2" aria-label="Accueil — Championnat du Monde de lancer d'avions en papier">
      <Image
        src={logo}
        alt="Championnat du Monde de lancer d'avions en papier"
        widths={[120, 200]}
        sizes="160px"
        class="h-9 w-auto sm:h-10"
        loading="eager"
      />
    </a>

    <nav class="hidden md:block" aria-label="Navigation principale">
      <Nav variant="desktop" pathname={pathname} />
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={helloAssoUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center rounded-full bg-orange px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-orange/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange"
      >
        S’inscrire
      </a>

      <details class="relative md:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md text-sky-deep marker:content-none hover:bg-sky/10"
          aria-label="Ouvrir le menu"
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="7" x2="20" y2="7" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="17" x2="20" y2="17" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-64 rounded-lg border border-sky/20 bg-white p-2 shadow-xl">
          <nav aria-label="Navigation principale (mobile)">
            <Nav variant="mobile" pathname={pathname} />
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>
