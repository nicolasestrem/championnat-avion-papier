---
import JsonLd from './JsonLd.astro';
import { buildHowTo } from '../../lib/schema';

interface Props {
  title: string;
  description: string;
  etapes: { texte: string; image?: string }[];
  totalTime?: string;
  image?: string;
}

const { title, description, etapes, totalTime, image } = Astro.props;
const data = buildHowTo(title, description, etapes, totalTime, image);
---

<JsonLd data={data} />
