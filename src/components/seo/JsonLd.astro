---
interface Props {
  data: object;
}

const { data } = Astro.props;
// JSON.stringify output is embedded in a script element; escape "<" so a stray
// "</script>" or "<!--" in text content can't break out of the script context.
const json = JSON.stringify(data).replace(/</g, '\\u003c');
---

<script type="application/ld+json" is:inline set:html={json} />
