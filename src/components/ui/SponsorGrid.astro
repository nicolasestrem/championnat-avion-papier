---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Sponsor {
  nom: string;
  url: string;
  logo?: ImageMetadata;
  descriptif: string;
}

interface Props {
  sponsors: Sponsor[];
}

const { sponsors } = Astro.props;
---

<ul class="grid list-none grid-cols-2 gap-4 p-0 sm:grid-cols-3 lg:grid-cols-4">
  {sponsors.map((sponsor) => (
    <li class="rounded-2xl border border-sky/15 bg-white p-4 text-center shadow-sm transition-shadow hover:shadow-md">
      <a href={sponsor.url} target="_blank" rel="noopener" class="flex h-full flex-col items-center">
        <div class="flex h-20 items-center justify-center">
          {sponsor.logo ? (
            <Image
              src={sponsor.logo}
              alt={`Logo ${sponsor.nom}`}
              widths={[160, 240]}
              sizes="200px"
              class="max-h-20 w-auto object-contain"
              loading="lazy"
            />
          ) : (
            <span class="font-brand text-lg font-bold text-sky-deep">{sponsor.nom}</span>
          )}
        </div>
        <p class="mt-3 font-semibold text-sky-deep">{sponsor.nom}</p>
        {sponsor.descriptif && <p class="mt-1 text-sm text-ink/65">{sponsor.descriptif}</p>}
      </a>
    </li>
  ))}
</ul>
