---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  dateLabel: string;
  ctaLabel: string;
  ctaHref: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { title, subtitle, dateLabel, ctaLabel, ctaHref, image, imageAlt = '' } = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-b from-sky/15 to-paper">
  <div class="mx-auto grid max-w-6xl items-center gap-8 px-4 py-12 md:grid-cols-2 md:py-16">
    <div>
      <p class="inline-flex items-center gap-2 rounded-full bg-sky-deep/10 px-3 py-1 text-sm font-semibold text-sky-deep">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4.5" width="18" height="17" rx="2" /><path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round" />
        </svg>
        {dateLabel}
      </p>
      <h1 class="mt-4 font-brand text-4xl font-bold leading-tight text-sky-deep sm:text-5xl">{title}</h1>
      {subtitle && <p class="mt-4 max-w-prose text-lg text-ink/80">{subtitle}</p>}
      <div class="mt-7">
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-orange px-6 py-3 text-base font-semibold text-white shadow-md transition-colors hover:bg-orange/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange"
        >
          {ctaLabel}
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
    </div>

    {image && (
      <div class="justify-self-center">
        <Image
          src={image}
          alt={imageAlt}
          widths={[400, 600, 900]}
          sizes="(min-width: 768px) 40vw, 90vw"
          class="w-full max-w-md rounded-2xl shadow-lg"
          loading="eager"
        />
      </div>
    )}
  </div>
</section>
