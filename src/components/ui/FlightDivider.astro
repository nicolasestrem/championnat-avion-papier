---
// Decorative dotted flight-trajectory divider. No props. Hidden from a11y tree.
---

<div class="my-10 flex justify-center px-4" aria-hidden="true">
  <svg viewBox="0 0 400 40" class="h-8 w-full max-w-2xl text-sky/60" fill="none" role="presentation">
    <path
      d="M4 34 C 90 34, 130 8, 200 8 S 320 30, 384 8"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-dasharray="1 9"
    />
    <g class="text-sky-deep">
      <path d="M384 8 l 12 -6 -4 6 4 6 z" fill="currentColor" transform="translate(-6,0)" />
    </g>
  </svg>
</div>
