---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  href: string;
  image: ImageMetadata;
  imageAlt: string;
  difficulte: 'facile' | 'intermediaire' | 'avance';
  typeVol: 'distance' | 'duree' | 'polyvalent';
  dureePliage: string;
}

const { title, href, image, imageAlt, difficulte, typeVol, dureePliage } = Astro.props;

const DIFFICULTE_LABEL: Record<Props['difficulte'], string> = {
  facile: 'Facile',
  intermediaire: 'Intermédiaire',
  avance: 'Avancé',
};

const TYPE_VOL_LABEL: Record<Props['typeVol'], string> = {
  distance: 'Distance',
  duree: 'Durée de vol',
  polyvalent: 'Polyvalent',
};
---

<article class="group h-full overflow-hidden rounded-2xl border border-sky/15 bg-white shadow-sm transition-shadow hover:shadow-md">
  <a href={href} class="flex h-full flex-col">
    <div class="aspect-[4/3] overflow-hidden bg-paper">
      <Image
        src={image}
        alt={imageAlt}
        widths={[300, 500, 700]}
        sizes="(min-width: 1024px) 320px, (min-width: 640px) 45vw, 90vw"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    </div>
    <div class="flex flex-1 flex-col p-4">
      <div class="flex flex-wrap gap-2">
        <span class="rounded-full bg-sky/15 px-2.5 py-0.5 text-xs font-semibold text-sky-deep">{TYPE_VOL_LABEL[typeVol]}</span>
        <span class="rounded-full bg-orange/10 px-2.5 py-0.5 text-xs font-semibold text-orange">{DIFFICULTE_LABEL[difficulte]}</span>
      </div>
      <h3 class="mt-3 font-brand text-lg font-bold leading-snug text-sky-deep transition-colors group-hover:text-orange">{title}</h3>
      <p class="mt-auto pt-3 text-sm text-ink/60">⏱ {dureePliage} de pliage</p>
    </div>
  </a>
</article>
