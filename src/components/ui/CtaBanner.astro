---
interface Props {
  heading: string;
  text?: string;
  href: string;
  label: string;
}

const { heading, text, href, label } = Astro.props;
const external = /^https?:\/\//.test(href);
---

<section class="my-12">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex flex-col items-start gap-5 rounded-2xl bg-sky-deep px-6 py-8 text-white sm:flex-row sm:items-center sm:justify-between sm:px-10">
      <div>
        <h2 class="font-brand text-2xl font-bold">{heading}</h2>
        {text && <p class="mt-2 max-w-prose text-white/85">{text}</p>}
      </div>
      <a
        href={href}
        {...(external ? { target: '_blank', rel: 'noopener' } : {})}
        class="inline-flex shrink-0 items-center gap-2 rounded-full bg-orange px-6 py-3 text-base font-semibold text-white shadow-md transition-colors hover:bg-orange/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        {label}
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</section>
