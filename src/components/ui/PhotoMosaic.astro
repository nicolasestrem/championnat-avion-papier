---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface MosaicItem {
  image: ImageMetadata;
  alt: string;
  href: string;
}

interface Props {
  /** First item is the large feature tile; the four others fill the right half. */
  items: MosaicItem[];
}

const { items } = Astro.props;
const [feature, ...rest] = items;
---

{feature && (
  <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
    <a
      href={feature.href}
      class="group col-span-2 aspect-[4/3] overflow-hidden rounded-2xl border border-sky/15 bg-white md:row-span-2 md:aspect-auto"
    >
      <Image
        src={feature.image}
        alt={feature.alt}
        widths={[500, 800, 1100]}
        sizes="(min-width: 768px) 48vw, 92vw"
        class="h-full w-full object-cover transition-transform duration-300 motion-safe:group-hover:scale-105"
        loading="lazy"
      />
    </a>
    {rest.map((item) => (
      <a
        href={item.href}
        class="group aspect-square overflow-hidden rounded-2xl border border-sky/15 bg-white"
      >
        <Image
          src={item.image}
          alt={item.alt}
          widths={[300, 500, 700]}
          sizes="(min-width: 768px) 23vw, 45vw"
          class="h-full w-full object-cover transition-transform duration-300 motion-safe:group-hover:scale-105"
          loading="lazy"
        />
      </a>
    ))}
  </div>
)}
